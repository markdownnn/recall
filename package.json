{
  "name": "recall",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "package": "rm -rf dist-ext recall-extension.zip && npm run build && (cd dist-ext && zip -qr -X ../recall-extension.zip . -x '*.map') && echo \"packaged -> recall-extension.zip\""
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@sqlite.org/sqlite-wasm": "^3.46.0-build1",
    "@xenova/transformers": "^2.17.2",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@playwright/test": "^1.45.0",
    "@preact/preset-vite": "^2.8.2",
    "@types/chrome": "^0.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
