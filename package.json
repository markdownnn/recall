{
  "name": "recall",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:fetch-model": "node scripts/fetch-model.mjs",
    "eval:build-corpus": "vite-node eval/lib/build-corpus.mjs",
    "eval": "npm run eval:fetch-model && vite-node eval/run.mjs --",
    "eval:bge": "vite-node eval/run-candidates.mjs",
    "eval:english": "npm run eval:fetch-model && vite-node eval/run.mjs -- --strip --min-prose=0.35 --golden=eval/english-golden.json",
    "models:manifest": "node scripts/r2-model-manifest.mjs",
    "models:upload-r2": "node scripts/upload-r2-models.mjs",
    "eval:ci": "npm run eval:fetch-model && vite-node eval/run.mjs -- --ci --strip --min-prose=0.35",
    "eval:ask": "npm run eval:fetch-model && vite-node eval/run-ask.mjs",
    "e2e": "playwright test",
    "package": "rm -rf dist-ext recall-extension.zip && npm run build && (cd dist-ext && zip -qr -X ../recall-extension.zip . -x '*.map') && echo \"packaged -> recall-extension.zip\""
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "@mozilla/readability": "^0.6.0",
    "@picocss/pico": "^2.1.1",
    "@sqlite.org/sqlite-wasm": "^3.46.0-build1",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@playwright/test": "^1.45.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/chrome": "^0.2.0",
    "linkedom": "^0.18.12",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
